generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  darkMode  Boolean  @default(false)
  createdAt DateTime @default(now())

  goals               Goals?
  meals               MealEntry[]
  workouts            WorkoutSession[]
  healthData          HealthData[]
  foods               Food[]
  mealPresets         MealPreset[]
  customExercises     CustomExercise[]
  workoutPresets      WorkoutPreset[]
  waterEntries        WaterEntry[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Goals {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calorieMin  Int      @default(2400)
  calorieMax  Int      @default(2600)
  proteinMin  Int      @default(176)
  proteinMax  Int      @default(200)
  carbsGoal   Int?
  fatGoal     Int?
  waterGoal   Float?
  startWeight Float?
  startDate   DateTime @default(now())
}

model MealEntry {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  mealType  String
  servingId String?
  serving   FoodServing? @relation(fields: [servingId], references: [id], onDelete: SetNull)
  quantity  Float        @default(1)

  foodNameSnapshot     String
  brandNameSnapshot    String?
  servingDescSnapshot  String?
  caloriesSnapshot     Float
  proteinSnapshot      Float
  carbsSnapshot        Float
  fatSnapshot          Float
  fiberSnapshot        Float?
  sugarSnapshot        Float?
  sodiumSnapshot       Float?
  saturatedFatSnapshot Float?
  addedSugarsSnapshot  Float?

  createdAt DateTime @default(now())

  @@index([userId, date])
}

model Food {
  id              String        @id @default(cuid())
  source          String
  fatSecretFoodId Int?          @unique
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  brandName       String?
  foodType        String
  foodUrl         String?
  createdAt       DateTime      @default(now())
  servings        FoodServing[]

  // Postgres treats NULL userIds as distinct, so multiple source='fatsecret'
  // rows (userId=null) can share a name. FS rows dedupe via fatSecretFoodId.
  // Custom rows (userId set) enforce per-user name uniqueness.
  @@unique([userId, name])
  @@index([source])
  @@index([userId])
}

model FoodServing {
  id                     String           @id @default(cuid())
  foodId                 String
  food                   Food             @relation(fields: [foodId], references: [id], onDelete: Cascade)
  fatSecretServingId     Int?
  description            String
  metricAmount           Float?
  metricUnit             String?
  measurementDescription String?
  numberOfUnits          Float?
  isDefault              Boolean          @default(false)
  calories               Float
  protein                Float
  carbs                  Float
  fat                    Float
  saturatedFat           Float?
  sugar                  Float?
  addedSugars            Float?
  fiber                  Float?
  sodium                 Float?
  createdAt              DateTime         @default(now())
  mealEntries            MealEntry[]
  presetItems            MealPresetItem[]

  @@unique([foodId, fatSecretServingId])
  @@index([foodId])
}

model WorkoutSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  splitDay    String
  exercises   Json
  durationMin Int?
  source      String   @default("manual")
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model HealthData {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  activeCalories  Float?
  restingCalories Float?
  steps           Int?
  heartRateAvg    Int?
  source          String   @default("health_auto_export")
  createdAt       DateTime @default(now())

  @@unique([userId, date])
}

model MealPreset {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  items     MealPresetItem[]
  createdAt DateTime         @default(now())

  @@unique([userId, name])
}

model CustomExercise {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  category  String
  muscles   Json
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model WorkoutPreset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  exercises Json
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model MealPresetItem {
  id                  String      @id @default(cuid())
  presetId            String
  preset              MealPreset  @relation(fields: [presetId], references: [id], onDelete: Cascade)
  servingId           String
  serving             FoodServing @relation(fields: [servingId], references: [id], onDelete: Cascade)
  quantity            Float       @default(1)
  foodNameSnapshot    String
  servingDescSnapshot String?

  @@index([presetId])
}

model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  amount    Float
  createdAt DateTime @default(now())

  @@index([userId, date])
}
