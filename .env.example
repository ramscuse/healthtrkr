# ── Local development ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/healthtrkr"
# DIRECT_URL is only used by `prisma migrate deploy` against pgbouncer/pooled
# databases (e.g. Vercel Postgres). Leave unset for local/Docker — Prisma falls
# back to DATABASE_URL. Set this in Vercel/cloud envs to the non-pooled URL.
# DIRECT_URL="postgresql://..."
JWT_SECRET="replace-with-a-long-random-string"
PORT=3001
VITE_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173

# FatSecret API — register at platform.fatsecret.com. We use OAuth 1.0a (signed
# requests), so no IP whitelist is required. Use the "Consumer Key" and "Shared
# Secret" from the FatSecret app dashboard, NOT the OAuth 2.0 client_id/secret.
FATSECRET_CONSUMER_KEY="your-consumer-key"
FATSECRET_CONSUMER_SECRET="your-shared-secret"

# ── Docker / production ───────────────────────────────────────────────────────
# When using docker-compose, DATABASE_URL is set automatically from these:
POSTGRES_USER=postgres
POSTGRES_PASSWORD="replace-with-a-strong-password"
# CORS_ORIGIN should be your public domain, e.g. https://healthtrkr.example.com
# DATA is the host path for persistent data (used by docker-compose.deploy.yml)
# DATA=/mnt/e/docker/healthtrkr

# EmailJS — required for password reset
# Create a template at emailjs.com with variables: {{to_email}}, {{reset_code}}
EMAILJS_SERVICE_ID="service_xxxxxxx"
EMAILJS_TEMPLATE_ID="template_xxxxxxx"
EMAILJS_PUBLIC_KEY="your_public_key"
EMAILJS_PRIVATE_KEY="your_private_key"
