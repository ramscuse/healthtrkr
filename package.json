{
  "name": "healthtrkr",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite src --host --config vite.config.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "prisma generate && vite build src --config vite.config.js",
    "start": "NODE_ENV=production node server/index.js",
    "postinstall": "prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node db/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset-password": "node db/reset-password.js",
    "db:seed-foods": "node db/seed-foods.js",
    "db:seed-off-foods": "node db/seed-off-foods.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.100.11",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "prisma": "^5.22.0",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "prisma": {
    "schema": "db/schema.prisma"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.11",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.7",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "tailwindcss": "^4.3.0",
    "vite": "^5.4.10"
  }
}
